{
  "info": {
    "name": "Test MergeFlow Step 7 release email (logout endpoint)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Log out and revoke the current session token",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}/logout",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "logout"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"mergeflow-test-session-token-for-admin-user\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{bearer_token}}",
              "type": "string"
            }
          ]
        }
      },
      "response": []
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "",
        "type": "string"
      }
    ]
  }
}
