{
  "info": {
    "name": "Test MergeFlow Notion sync (retest 2)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "health_check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        },
        "description": "Return service health status"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200 or 500\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 500]);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
